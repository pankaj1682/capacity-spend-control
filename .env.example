# Database — PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/capacity_spend_control

# Session secret — any long random string (required, minimum 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Node environment — set to "production" in deployed environments
NODE_ENV=development

# Port the API server listens on (set automatically by Replit; set manually for local dev)
PORT=8080
